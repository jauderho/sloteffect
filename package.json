{
  "name": "sloteffect",
  "version": "1.1.0",
  "description": "Slot-machine-style rolls for numbers, letters, and text in React. Dependency-free, accessible, reduced-motion aware.",
  "keywords": [
    "react",
    "react-component",
    "animation",
    "slot-machine",
    "odometer",
    "counter",
    "countup",
    "number",
    "animated-numbers",
    "number-animation",
    "text-animation",
    "tabular-nums",
    "ui"
  ],
  "license": "MIT",
  "author": "Jauder Ho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jauderho/sloteffect.git"
  },
  "homepage": "https://jauderho.github.io/sloteffect/",
  "bugs": {
    "url": "https://github.com/jauderho/sloteffect/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "bun run bench/run.ts",
    "build": "tsup",
    "build:index": "bun run scripts/build-index.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19",
    "react": "^19.0.0",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
